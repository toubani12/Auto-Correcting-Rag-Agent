# ============================================================================
# LLM provider selection — set ONE of the three API keys.
# The provider is auto-detected at startup in this priority order:
#   1. GEMINI_API_KEY  (Google Gemini)
#   2. OPENAI_API_KEY  (OpenAI)
#   3. GROK_API_KEY    (xAI Grok)
# You can also force a provider explicitly with LLM_PROVIDER.
# ============================================================================

# LLM_PROVIDER=gemini   # one of: gemini | openai | grok  (optional override)

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_EMBED_MODEL=models/text-embedding-004

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- xAI Grok ---
GROK_API_KEY=
GROK_MODEL=grok-2-latest
# Grok has no embedding API — when grok is selected, embeddings fall back to
# the local HuggingFace model below.
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================================
# Vector store
# ============================================================================
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=gcn_eeg_papers
RETRIEVER_TOP_K=5

# ============================================================================
# Web search tool (used when vector retrieval is weak)
# ============================================================================
# WEB_SEARCH_PROVIDER one of: duckduckgo | tavily   (default: duckduckgo, no key needed)
WEB_SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# ============================================================================
# Agent behaviour
# ============================================================================
MAX_RETRIEVE_ITERATIONS=3
RELEVANCE_THRESHOLD=0.5
LLM_TEMPERATURE=0.0

# ============================================================================
# API server
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins for the Angular frontend
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
LOG_LEVEL=INFO
